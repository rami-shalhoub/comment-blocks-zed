{
  "small separator": {
    "prefix": "com-sep-sm",
    "body": ["--==========${1:Comment}=========="],
    "description": "small comment separator"
  },
  "medium separator": {
    "prefix": "com-sep-md",
    "body": ["--===============${1:Comment}=============="],
    "description": "medium comment separator"
  },
  "large separator": {
    "prefix": "com-sep-lg",
    "body": ["--====================${1:Comment}===================="],
    "description": "large comment separator"
  },
  "Xlarge separator": {
    "prefix": "com-sep-xl",
    "body": ["--=========================${1:Comment}========================="],
    "description": "extra large comment separator"
  },
  "XXlarge separator": {
    "prefix": "com-sep-xxl",
    "body": ["--==============================${1:Comment}=============================="],
    "description": "double extra large comment separator"
  },

  "small header": {
    "prefix": "com-head-sm",
    "body": [
      "--================================",
      "--===       ${1:Comment}            ===",
      "--================================"
    ],
    "description": "small comment header"
  },
  "medium header": {
    "prefix": "com-head-md",
    "body": [
      "--==========================================",
      "--===            ${1:Comment}                 ===",
      "--=========================================="
    ],
    "description": "medium comment header"
  },
  "large header": {
    "prefix": "com-head-lg",
    "body": [
      "--====================================================",
      "--===                 ${1:Comment}                      ===",
      "--===================================================="
    ],
    "description": "large comment header"
  },
  "Xlarge header": {
    "prefix": "com-head-xl",
    "body": [
      "--==============================================================",
      "--===                     ${1:Comment}                           ===",
      "--=============================================================="
    ],
    "description": "extra large comment header"
  },
  "XXlarge header": {
    "prefix": "com-head-xxl",
    "body": [
      "--========================================================================",
      "--===                           ${1:Comment}                                ===",
      "--========================================================================"
    ],
    "description": "double extra large comment header"
  },

  "small block": {
    "prefix": "com-blk-sm",
    "body": [
      "-- --------------------------------",
      "--          ${1:Comment}          ",
      "--[[ ${2:body} ",
      "]]",
      "-- --------------------------------"
    ],
    "description": "small comment block"
  },
  "medium block": {
    "prefix": "com-blk-md",
    "body": [
      "-- ------------------------------------------",
      "--               ${1:Comment}               ",
      "--[[ ${2:body} ",
      "]]",
      "-- ------------------------------------------"
    ],
    "description": "medium comment block"
  },
  "large block": {
    "prefix": "com-blk-lg",
    "body": [
      "-- ----------------------------------------------------",
      "--                    ${1:Comment}                    ",
      "--[[ ${2:body} ",
      "]]",
      "-- ----------------------------------------------------"
    ],
    "description": "large comment block"
  },
  "Xlarge block": {
    "prefix": "com-blk-xl",
    "body": [
      "-- --------------------------------------------------------------",
      "--                         ${1:Comment}                         ",
      "--[[ ${2:body} ",
      "]]",
      "-- --------------------------------------------------------------"
    ],
    "description": "extra large comment block"
  },
  "XXlarge block": {
    "prefix": "com-blk-xxl",
    "body": [
      "-- ------------------------------------------------------------------------",
      "--                              ${1:Comment}                              ",
      "--[[ ${2:body} ",
      "]]",
      "-- ------------------------------------------------------------------------"
    ],
    "description": "double extra large comment block"
  },
  
